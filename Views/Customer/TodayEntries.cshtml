@model DuongVanDung.WebApp.Models.Customer.TodayEntryViewModel
@{
    ViewData["Title"] = "Nhập hôm nay";
    var kho = Model.FilterKho;
    var sp  = Model.FilterSanPham;
}

<!-- ── Header ─────────────────────────────────────────────────── -->
<div class="cust-page-header">
    <div>
        <p class="eyebrow">Quản lý khách hàng</p>
        <h1>Nhập hôm nay</h1>
        <p class="cust-subtitle">@DuongVanDung.WebApp.Helpers.VietnamTime.Now.ToString("dddd, dd/MM/yyyy", new System.Globalization.CultureInfo("vi-VN"))</p>
    </div>
    <a href="/Customer/ExportTodayEntries?filterKho=@kho&filterSanPham=@sp" class="btn-excel">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="18" x2="12" y2="12"/>
            <line x1="9" y1="15" x2="15" y2="15"/>
        </svg>
        Xuất Excel
    </a>
</div>

<!-- ── Stat cards ─────────────────────────────────────────────── -->
<div class="today-kpi-row">
    <div class="today-kpi today-kpi--blue">
        <div class="today-kpi__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
        </div>
        <div class="today-kpi__body">
            <span class="today-kpi__label">Tổng phiếu</span>
            <strong class="today-kpi__val">@Model.SoPhieu.ToString("#,0")</strong>
        </div>
    </div>
    <div class="today-kpi today-kpi--green">
        <div class="today-kpi__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 6l3 1m0 0l-3 9a5 5 0 006.9 4.7M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5 5 0 01-6.9 4.7M18 7l-3 9M18 7l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
            </svg>
        </div>
        <div class="today-kpi__body">
            <div class="today-kpi__split">
                <div>
                    <span class="today-kpi__label">Cà phê</span>
                    <strong class="today-kpi__val">@Model.TongKgCaPhe.ToString("#,0.##") kg</strong>
                </div>
                <div>
                    <span class="today-kpi__label">Tiêu</span>
                    <strong class="today-kpi__val">@Model.TongKgTieu.ToString("#,0.##") kg</strong>
                </div>
            </div>
        </div>
    </div>
    <div class="today-kpi today-kpi--gold">
        <div class="today-kpi__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
            </svg>
        </div>
        <div class="today-kpi__body">
            <div class="today-kpi__split">
                <div>
                    <span class="today-kpi__label">Cà phê</span>
                    <strong class="today-kpi__val">@Model.TongTienCaPhe.ToString("#,0") ₫</strong>
                </div>
                <div>
                    <span class="today-kpi__label">Tiêu</span>
                    <strong class="today-kpi__val">@Model.TongTienTieu.ToString("#,0") ₫</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Filter bar ─────────────────────────────────────────────── -->
<div class="today-filter-bar">
    <div class="today-filter-group">
        <span class="today-filter-label">Kho</span>
        <div class="today-filter-pills">
            <a href="?filterKho=all&filterSanPham=@sp"      class="today-pill @(kho=="all"      ?"is-active":"")">Tất cả</a>
            <a href="?filterKho=dvd&filterSanPham=@sp"      class="today-pill @(kho=="dvd"      ?"is-active":"")">Dương Văn Dũng</a>
            <a href="?filterKho=thongdao&filterSanPham=@sp" class="today-pill @(kho=="thongdao" ?"is-active":"")">Thông Đào</a>
            <a href="?filterKho=ymoal&filterSanPham=@sp"    class="today-pill @(kho=="ymoal"    ?"is-active":"")">Ymoal</a>
        </div>
    </div>
    <div class="today-filter-sep"></div>
    <div class="today-filter-group">
        <span class="today-filter-label">Sản phẩm</span>
        <div class="today-filter-pills">
            <a href="?filterKho=@kho&filterSanPham=all"   class="today-pill @(sp=="all"  ?"is-active":"")">Tất cả</a>
            <a href="?filterKho=@kho&filterSanPham=caphe" class="today-pill today-pill--caphe @(sp=="caphe"?"is-active":"")">Cà phê</a>
            <a href="?filterKho=@kho&filterSanPham=tieu"  class="today-pill today-pill--tieu  @(sp=="tieu" ?"is-active":"")">Tiêu</a>
        </div>
    </div>
    <span class="cust-record-count" style="margin-left:auto">@Model.SoPhieu bản ghi</span>
</div>

<!-- ── Table ──────────────────────────────────────────────────── -->
<div class="cust-table-wrap">
    <table class="cust-table" id="tblTodayEntries">
        <thead>
            <tr>
                <th class="col-stt">STT</th>
                <th class="col-ngaynhap">Ngày nhập</th>
                <th class="col-name">Tên khách hàng</th>
                <th class="col-gender">Giới tính</th>
                <th class="col-sdt">Số ĐT</th>
                <th class="col-cccd">Số CCCD</th>
                <th class="col-diachi">Địa chỉ</th>
                <th class="col-dob">Ngày sinh</th>
                <th class="col-ngaycap">Ngày cấp</th>
                <th class="col-soluong">Số lượng</th>
                <th class="col-thanhtien">Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @{ int stt = 1; }
            @foreach (var r in Model.Rows)
            {
                <tr class="cust-row">
                    <td class="col-stt"><span class="stt-num">@stt</span></td>
                    <td class="col-ngaynhap">
                        <span class="ngaynhap-date">@r.NgayNhap.ToString("dd/MM/yyyy")</span>
                        <span class="ngaynhap-time">@r.NgayNhap.ToString("HH:mm")</span>
                        <div style="margin-top:2px">
                            <span class="sp-badge sp-badge--@(r.SanPham=="Cà phê"?"caphe":"tieu")">@r.SanPham</span>
                            <span class="kho-badge kho-badge--@KhoBadgeKey(r.Kho)" style="margin-left:2px">@r.Kho</span>
                        </div>
                    </td>
                    <td class="col-name">
                        <div class="cust-name-cell">
                            <div class="cust-avatar" style="--av-color:@SanPhamColor(r.SanPham)">
                                @FirstLetter(r.TenKhachHang)
                            </div>
                            <div class="cust-name-info">
                                <strong>@r.TenKhachHang</strong>
                                <small class="cust-note">@r.LoaiNhap</small>
                            </div>
                        </div>
                    </td>
                    <td class="col-gender">
                        @if (!string.IsNullOrEmpty(r.GioiTinh))
                        {
                            <span class="gender-badge gender-badge--@r.GioiTinh.ToLower().Replace("ữ","u")">@r.GioiTinh</span>
                        }
                        else { <span class="text-muted-sm">—</span> }
                    </td>
                    <td class="col-sdt">
                        @if (!string.IsNullOrEmpty(r.SDT))
                        { <a href="tel:@r.SDT" class="sdt-link">@r.SDT</a> }
                        else { <span class="text-muted-sm">—</span> }
                    </td>
                    <td class="col-cccd">
                        <span class="cccd-val">@(string.IsNullOrEmpty(r.CCCD) ? "—" : r.CCCD)</span>
                    </td>
                    <td class="col-diachi">
                        <span class="diachi-text" title="@r.DiaChi">@(string.IsNullOrEmpty(r.DiaChi) ? "—" : r.DiaChi)</span>
                    </td>
                    <td class="col-dob">
                        @if (r.NgaySinh.HasValue)
                        { <span>@r.NgaySinh.Value.ToString("dd/MM/yyyy")</span> }
                        else { <span class="text-muted-sm">—</span> }
                    </td>
                    <td class="col-ngaycap">
                        @if (r.NgayCap.HasValue)
                        { <span>@r.NgayCap.Value.ToString("dd/MM/yyyy")</span> }
                        else { <span class="text-muted-sm">—</span> }
                    </td>
                    <td class="col-soluong">
                        <span class="soluong-val">@r.QuyChuan.ToString("#,0.##")</span>
                        <span class="soluong-unit">kg</span>
                    </td>
                    <td class="col-thanhtien">
                        <span class="thanhtien-val">@r.ThanhTien.ToString("#,0")</span>
                        @if (!string.IsNullOrEmpty(r.PhuongThuc))
                        {
                            <span class="pt-badge pt-badge--@r.PhuongThuc.ToLower()" style="margin-top:2px;display:block">@r.PhuongThuc</span>
                        }
                    </td>
                </tr>
                stt++;
            }
        </tbody>
    </table>

    @if (Model.Rows.Count == 0)
    {
        <div class="table-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <path d="M16 2v4M8 2v4M3 10h18M8 14h8M8 18h5"/>
            </svg>
            <p>Chưa có phiếu nhập nào trong ngày hôm nay</p>
        </div>
    }
</div>

@functions {
    static string FirstLetter(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts[^1].Substring(0, 1).ToUpper();
    }
    static string SanPhamColor(string sp) => sp == "Cà phê" ? "#7c3aed" : "#16a34a";
    static string KhoBadgeKey(string kho) => kho switch {
        "Dương Văn Dũng" => "dvd",
        "Thông Đào"      => "thongdao",
        "Ymoal"          => "ymoal",
        _                => "other"
    };
}
