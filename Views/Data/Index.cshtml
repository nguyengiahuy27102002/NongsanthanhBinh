@{
    ViewData["Title"] = "Dữ liệu kho hàng";
}

<div class="di-shell">

    <!-- ══ HEADER ═══════════════════════════════════════════════════════════ -->
    <div class="di-header">
        <div class="di-header__copy">
            <p class="eyebrow">Hệ thống</p>
            <h1>Dữ liệu kho hàng</h1>
            <p class="di-header__sub">Chọn kho và bảng cần xem. Hỗ trợ lọc theo ngày, khoảng thời gian và xuất Excel.</p>
        </div>
        <div class="di-header__hint">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/>
                <polyline points="13 2 13 9 20 9"/>
            </svg>
            <span>Click chuột phải để mở menu nhanh</span>
        </div>
    </div>

    <!-- ══ KHO DƯƠNG VĂN DŨNG ═══════════════════════════════════════════════ -->
    <section class="di-warehouse di-warehouse--blue">
        <div class="di-warehouse__header">
            <div class="di-warehouse__badge">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 10l9-6 9 6v10h-4v-6H7v6H3z"/>
                </svg>
            </div>
            <div>
                <h2>Kho Dương Văn Dũng</h2>
                <p>Kho chính — đầy đủ dữ liệu nhập lẻ, nhập sỉ, xuất hàng</p>
            </div>
        </div>

        <div class="di-sections">
            <!-- Nhập hàng -->
            <div class="di-section">
                <div class="di-section__label di-section__label--in">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 4v10m0 0l-4-4m4 4l4-4M5 18h14"/>
                    </svg>
                    Nhập hàng
                </div>
                <div class="di-tiles">
                    <a asp-action="Table" asp-route-kho="dvd" asp-route-bang="caphe-le" class="di-tile di-tile--caphe">
                        <div class="di-tile__icon">☕</div>
                        <div class="di-tile__body">
                            <strong>Cà phê lẻ</strong>
                            <span>Khách hàng mua lẻ tại kho DVD</span>
                        </div>
                        <span class="di-tile__tag di-tile__tag--le">Lẻ</span>
                        <svg class="di-tile__arrow" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                    <a asp-action="Table" asp-route-kho="dvd" asp-route-bang="caphe-si" class="di-tile di-tile--caphe">
                        <div class="di-tile__icon">☕</div>
                        <div class="di-tile__body">
                            <strong>Cà phê sỉ</strong>
                            <span>Khách hàng mua sỉ tại kho DVD</span>
                        </div>
                        <span class="di-tile__tag di-tile__tag--si">Sỉ</span>
                        <svg class="di-tile__arrow" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                    <a asp-action="Table" asp-route-kho="dvd" asp-route-bang="tieu-le" class="di-tile di-tile--tieu">
                        <div class="di-tile__icon">🫙</div>
                        <div class="di-tile__body">
                            <strong>Tiêu lẻ</strong>
                            <span>Khách hàng bán tiêu lẻ tại kho DVD</span>
                        </div>
                        <span class="di-tile__tag di-tile__tag--le">Lẻ</span>
                        <svg class="di-tile__arrow" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                    <a asp-action="Table" asp-route-kho="dvd" asp-route-bang="tieu-si" class="di-tile di-tile--tieu">
                        <div class="di-tile__icon">🫙</div>
                        <div class="di-tile__body">
                            <strong>Tiêu sỉ</strong>
                            <span>Khách hàng bán tiêu sỉ tại kho DVD</span>
                        </div>
                        <span class="di-tile__tag di-tile__tag--si">Sỉ</span>
                        <svg class="di-tile__arrow" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                </div>
            </div>

            <!-- Xuất hàng -->
            <div class="di-section">
                <div class="di-section__label di-section__label--out">
                    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 20V10m0 0l-4 4m4-4l4 4M5 4h14"/>
                    </svg>
                    Xuất hàng
                </div>
                <div class="di-tiles">
                    <a asp-action="Table" asp-route-kho="dvd" asp-route-bang="xuat-caphe" class="di-tile di-tile--xuat">
                        <div class="di-tile__icon">📤</div>
                        <div class="di-tile__body">
                            <strong>Xuất cà phê</strong>
                            <span>Giao hàng / xuất kho cà phê</span>
                        </div>
                        <span class="di-tile__tag di-tile__tag--xuat">Xuất</span>
                        <svg class="di-tile__arrow" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                    <a asp-action="Table" asp-route-kho="dvd" asp-route-bang="xuat-tieu" class="di-tile di-tile--xuat">
                        <div class="di-tile__icon">📤</div>
                        <div class="di-tile__body">
                            <strong>Xuất tiêu</strong>
                            <span>Giao hàng / xuất kho tiêu</span>
                        </div>
                        <span class="di-tile__tag di-tile__tag--xuat">Xuất</span>
                        <svg class="di-tile__arrow" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </section>

