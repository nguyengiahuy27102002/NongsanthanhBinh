@model ErrorViewModel
@{
    ViewData["Title"] = "Có lỗi xảy ra";
}

<section class="placeholder-shell">
    <div class="overview-card">
        <p class="eyebrow">System Status</p>
        <h1>Không thể xử lý yêu cầu của bạn lúc này</h1>
        <p class="lead-copy">
            Hệ thống vừa gặp lỗi trong quá trình xử lý. Bạn có thể quay lại dashboard hoặc thử lại sau.
        </p>

        @if (Model.ShowRequestId)
        {
            <div class="account-chip-row">
                <div class="account-chip">
                    <span>Mã yêu cầu</span>
                    <strong>@Model.RequestId</strong>
                </div>
            </div>
        }

        <a asp-controller="Dashboard" asp-action="Index" class="inline-action">Quay lại dashboard</a>
    </div>
</section>
