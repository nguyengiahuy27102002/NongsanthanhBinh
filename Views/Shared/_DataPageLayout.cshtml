                       class="ctx-menu__item @(IsTable("ymoal","caphe-le") ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M12 4v10m0 0l-4-4m4 4l4-4M5 18h14"/></svg>
                        Nhập cà phê lẻ
                    </a>
                    <a asp-controller="Data" asp-action="Table" asp-route-kho="ymoal" asp-route-bang="caphe-si"
                       class="ctx-menu__item @(IsTable("ymoal","caphe-si") ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M12 4v10m0 0l-4-4m4 4l4-4M5 18h14"/></svg>
                        Nhập cà phê sỉ
                    </a>
                    <a asp-controller="Data" asp-action="Table" asp-route-kho="ymoal" asp-route-bang="tieu-le"
                       class="ctx-menu__item @(IsTable("ymoal","tieu-le") ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M12 4v10m0 0l-4-4m4 4l4-4M5 18h14"/></svg>
                        Nhập tiêu lẻ
                    </a>
                    <a asp-controller="Data" asp-action="Table" asp-route-kho="ymoal" asp-route-bang="tieu-si"
