                        Nhập tiêu lẻ
                    </a>
                    <a asp-controller="Data" asp-action="Table" asp-route-kho="dvd" asp-route-bang="tieu-si"
                       class="ctx-menu__item @(IsTable("dvd","tieu-si") ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M12 4v10m0 0l-4-4m4 4l4-4M5 18h14"/></svg>
