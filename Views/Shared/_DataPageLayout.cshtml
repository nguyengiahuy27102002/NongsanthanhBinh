@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentKho    = Context.Request.Query["kho"].ToString();
    var currentBang   = Context.Request.Query["bang"].ToString();

    bool IsTable(string kho, string bang) =>
        currentKho == kho && currentBang == bang && currentAction == "Table";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nông sản Thanh Bình</title>
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin="anonymous" />
    <link href="https://fonts.bunny.net/css?family=inter:400,500,600,700,800,900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DuongVanDung.WebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm portal-nav">
            <div class="container-fluid portal-container">
                <a class="navbar-brand portal-brand" asp-controller="Home" asp-action="Index">Nông sản Thanh Bình</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">← Bảng điều khiển</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Data" asp-action="Index">Dữ liệu</a>
                        </li>
                    </ul>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-logout">Đăng xuất</button>
                    </form>
                </div>
            </div>
        </nav>
    </header>

    <div class="portal-container">
        <main role="main" class="pb-3">
            <div class="cust-shell" id="dataShell">

                <!-- ── CONTEXT MENU ─────────────────────────────────────── -->
                <div id="ctxMenu" class="ctx-menu" role="menu" aria-label="Menu dữ liệu">
                    <div class="ctx-menu__header">Dữ liệu kho</div>

                    <a asp-controller="Data" asp-action="Index"
                       class="ctx-menu__item @(currentAction == "Index" ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M3 10l9-6 9 6v10h-4v-6H7v6H3z"/></svg>
                        Tổng quan
                    </a>

                    <div class="ctx-menu__divider"></div>
                    <div class="ctx-menu__section">Kho Dương Văn Dũng</div>
                    <a asp-controller="Data" asp-action="Table" asp-route-kho="dvd" asp-route-bang="caphe-le"
                       class="ctx-menu__item @(IsTable("dvd","caphe-le") ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M12 4v10m0 0l-4-4m4 4l4-4M5 18h14"/></svg>
                        Nhập cà phê lẻ
