<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nông sản Thanh Bình</title>
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin="anonymous" />
    <link href="https://fonts.bunny.net/css?family=inter:400,500,600,700,800,900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DuongVanDung.WebApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm portal-nav">
            <div class="container-fluid portal-container">
                <a class="navbar-brand portal-brand" asp-controller="Home" asp-action="Index">Nông sản Thanh Bình</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">← Bảng điều khiển</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Product" asp-action="TonKho">Báo cáo sản phẩm</a>
                        </li>
                    </ul>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-logout">Đăng xuất</button>
                    </form>
                </div>
            </div>
        </nav>
    </header>

    <div class="portal-container">
        <main role="main" class="pb-3">
            <div class="cust-shell" id="custShell">
                <!-- ── CONTEXT MENU ──────────────────────────── -->
                @{
                    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
                }
                <div id="ctxMenu" class="ctx-menu" role="menu">
                    <div class="ctx-menu__header">Sản phẩm</div>
                    <a asp-controller="Product" asp-action="TonKho"
                       class="ctx-menu__item @(currentAction == "TonKho" ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        Tồn kho
                    </a>
                    <a asp-controller="Product" asp-action="StockMovement"
                       class="ctx-menu__item @(currentAction == "StockMovement" ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>
                        Nhập – Xuất – Tồn
                    </a>
                    <a asp-controller="Product" asp-action="Quality"
                       class="ctx-menu__item @(currentAction == "Quality" ? "is-active" : "")">
                        <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        Chất lượng hàng hóa
                    </a>
                    <div class="ctx-menu__divider"></div>
                    <div class="ctx-menu__section">Khách hàng</div>
                    <a asp-controller="Customer" asp-action="Index" class="ctx-menu__item">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                        Danh sách khách hàng
                    </a>
                </div>

                <div id="ctxOverlay" class="ctx-overlay" hidden></div>

                <div class="cust-content">
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="portal-container">&copy; 2026 - Nông sản Thanh Bình</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    (function () {
        var menu    = document.getElementById('ctxMenu');
        var overlay = document.getElementById('ctxOverlay');
        var shell   = document.getElementById('custShell');
        function showMenu(x, y) {
            menu.style.left = Math.min(x, window.innerWidth  - menu.offsetWidth  - 8) + 'px';
            menu.style.top  = Math.min(y, window.innerHeight - menu.offsetHeight - 8) + 'px';
            menu.classList.add('is-open');
            overlay.hidden = false;
        }
        function hideMenu() { menu.classList.remove('is-open'); overlay.hidden = true; }
        shell.addEventListener('contextmenu', function (e) {
            if (e.target.closest('a,button,input,select,textarea,th,td')) return;
            e.preventDefault(); showMenu(e.clientX, e.clientY);
        });
        overlay.addEventListener('click', hideMenu);
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') hideMenu(); });
    })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
